# ─── Application ───────────────────────────────────────────────────────────────
APP_NAME=Resileon API
APP_VERSION=1.0.0
DEBUG=false

# ─── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite — no extra dependencies required)
DATABASE_URL=sqlite+aiosqlite:///./resileon.db
DATABASE_URL_SYNC=sqlite:///./resileon.db

# Production (PostgreSQL — uncomment and replace values)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/resileon
# DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/resileon

# ─── Redis (optional) ──────────────────────────────────────────────────────────
# API works without Redis; caching is silently bypassed if unavailable.
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_FREE=50/day
RATE_LIMIT_PRO=10000/day
RATE_LIMIT_DEFAULT=200/minute

# ─── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of origins allowed to call the API.
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ─── Data Safety ───────────────────────────────────────────────────────────────
# Minimum hours to hold data before publishing. Do NOT set below 1.
DATA_DELAY_HOURS=1
